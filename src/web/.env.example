# Copy to `.env.local` for local `npm run dev` (see docker-compose `web` service for Docker values).
# Generate a production secret: `npx auth secret` or `openssl rand -base64 32`

AUTH_SECRET=lastmile-tms-dev-secret-change-in-production
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# Backend API — must match where Kestrel listens (see Api Properties/launchSettings.json → http://localhost:8080).
# If you run the API without launchSettings, use the URL printed by `dotnet run` (often http://localhost:5000).
# Driver photos in the browser use this host — wrong port = broken images.
# Full Docker stack: `API_URL` for server-side calls should be the API base (e.g. http://api:8080 in compose, or http://localhost:8080 from host).
NEXT_PUBLIC_API_URL=http://localhost:8080
API_URL=http://localhost:8080
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=replace-with-mapbox-token
