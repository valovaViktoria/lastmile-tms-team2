# Generate DASHBOARD__PASSWORDHASH with:
# docker run --rm caddy:2-alpine caddy hash-password --plaintext "your-password"
# In this .env file, escape each "$" as "$$" for docker compose env_file.
Email__SendGridApiKey=
Email__FromEmail=
Email__FromName=
DASHBOARD__USERNAME=
DASHBOARD__PASSWORD=
DASHBOARD__PASSWORDHASH=
