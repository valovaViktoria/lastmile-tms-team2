{
	auto_https off
}

:80 {
	# NextAuth endpoints (must be before /api/*)
	handle /api/auth/* {
		reverse_proxy web:3000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# API backend
	handle /api/* {
		reverse_proxy api:8080
	}

	# OAuth/OpenIddict endpoints
	handle /connect/* {
		reverse_proxy api:8080
	}

	# SignalR hubs (WebSocket support)
	handle /hubs/* {
		reverse_proxy api:8080
	}

	# Swagger UI
	handle /swagger/* {
		reverse_proxy api:8080
	}

	# GraphQL
	handle /graphql* {
		reverse_proxy api:8080
	}

	# Hangfire dashboard
	handle /hangfire* {
		reverse_proxy api:8080
	}

	# Seq log viewer
	handle /seq/* {
		uri strip_prefix /seq
		reverse_proxy seq:80
	}

	# Next.js web app (default)
	handle {
		reverse_proxy web:3000 {
			header_up Host {host}
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}
